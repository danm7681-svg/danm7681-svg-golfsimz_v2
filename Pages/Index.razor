@page "/"
@using golfsimz_v2.Models
@using golfsimz_v2.Services
@inject IPhysicsService PhysicsService
@inject IJSRuntime JSRuntime

<div class="app-container">
    <!-- 3D Viewport -->
    <div class="viewport" style="flex:1; position:relative; background:#0a0a1a; overflow:hidden;">
        <canvas id="threeCanvas" style="width:100%; height:100%; display:block;"></canvas>
        <div class="birdseye-overlay" style="position:absolute; top:20px; right:20px; width:320px; height:420px; border-radius:12px; border:2px solid #2a2a4a; overflow:hidden; background:#0a0a1a; box-shadow:0 4px 24px rgba(0,0,0,0.9);">
            <canvas id="birdseyeCanvas" width="320" height="420"></canvas>
        </div>
    </div>

    <!-- Data Panel -->
    <div class="data-panel">
        <div class="metric">
            <span class="label">CARRY</span>
            <span class="value">@(Result?.CarryYards.ToString("F1") ?? "---")</span>
            <span class="unit">yds</span>
        </div>
        <div class="metric">
            <span class="label">TOTAL</span>
            <span class="value">@(Result?.TotalYards.ToString("F1") ?? "---")</span>
            <span class="unit">yds</span>
        </div>
        <div class="metric">
            <span class="label">BALL SPEED</span>
            <span class="value">@(Input.BallSpeedMph.ToString("F0"))</span>
            <span class="unit">mph</span>
        </div>
        <div class="metric">
            <span class="label">LAUNCH</span>
            <span class="value">@(Input.LaunchAngleDeg.ToString("F1"))</span>
            <span class="unit">deg</span>
        </div>
        <div class="metric">
            <span class="label">HEIGHT</span>
            <span class="value">@(Result?.ApexFeet.ToString("F0") ?? "---")</span>
            <span class="unit">ft</span>
        </div>
        <div class="metric">
            <span class="label">LANDING</span>
            <span class="value">@(Result?.LandingAngleDeg.ToString("F0") ?? "---")</span>
            <span class="unit">deg</span>
        </div>
    </div>

    <!-- Editable Tiles -->
    <div class="tiles-bar">
        <div class="tile">
            <span class="tile-label">CLUB</span>
            <input @bind="Input.Club" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">BALL SPEED</span>
            <input @bind="Input.BallSpeedMph" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">LAUNCH</span>
            <input @bind="Input.LaunchAngleDeg" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">BACKSPIN</span>
            <input @bind="Input.BackspinRpm" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">SIDESPIN</span>
            <input @bind="Input.SidespinRpm" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">SIDE ANGLE</span>
            <input @bind="Input.SideAngleDeg" type="number" class="tile-input" />
        </div>
        <button @onclick="Simulate" class="run-btn">▶</button>
    </div>
</div>

@code {
    private ShotInput Input { get; set; } = new();
    private SimulationResult? Result { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(300);
            await JSRuntime.InvokeVoidAsync("init3DTracer", "threeCanvas");
            await Task.Delay(100);
            await Simulate();
        }
    }

    private async Task Simulate()
    {
        Result = PhysicsService.Simulate(Input);
        await RenderTrajectory(Result);
        StateHasChanged();
    }

    private async Task RenderTrajectory(SimulationResult result)
    {
        var points = result.Trajectory.Select(p => new
        {
            x = p.OfflineYards,
            y = p.AltitudeFeet / 3.28084f,
            z = p.DownrangeYards
        }).ToArray();

        var json = System.Text.Json.JsonSerializer.Serialize(points);
        await JSRuntime.InvokeVoidAsync("update3DTracer", json);
        await JSRuntime.InvokeVoidAsync("drawBirdseye", "birdseyeCanvas", json);
    }
}