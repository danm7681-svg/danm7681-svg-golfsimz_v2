@page "/"
@inject IJSRuntime JS
@inject IPhysicsService Physics

<PageTitle>Golfsimz V2</PageTitle>

<div class="app-container">
    <div class="viewport">
        <canvas id="threeCanvas"></canvas>
        <div class="birdseye-overlay">
            <canvas id="birdseyeCanvas"></canvas>
        </div>
    </div>

    <div class="data-panel">
        @if (result != null)
        {
            <div class="metric">
                <span class="label">Carry</span>
                <span class="value">@result.CarryYards.ToString("F1")</span>
                <span class="unit">yds</span>
            </div>
            <div class="metric">
                <span class="label">Total</span>
                <span class="value">@result.TotalYards.ToString("F1")</span>
                <span class="unit">yds</span>
            </div>
            <div class="metric">
                <span class="label">Apex</span>
                <span class="value">@result.ApexFeet.ToString("F1")</span>
                <span class="unit">ft</span>
            </div>
            <div class="metric">
                <span class="label">Hang Time</span>
                <span class="value">@result.HangTimeSeconds.ToString("F2")</span>
                <span class="unit">s</span>
            </div>
            <div class="metric">
                <span class="label">Offline</span>
                <span class="value" style="color:@(result.OfflineYards < 0 ? "#ff4455" : "#00ff88")">
                    @(result.OfflineYards < 0 ? "L" : "R") @Math.Abs(result.OfflineYards).ToString("F1")
                </span>
                <span class="unit">yds</span>
            </div>
        }
    </div>

    <div class="tiles-bar">
        <div class="tile">
            <span class="tile-label">Speed</span>
            <input type="number" class="tile-input" @bind-value="ballSpeed" @bind-value:event="oninput" />
        </div>
        <div class="tile">
            <span class="tile-label">Launch</span>
            <input type="number" class="tile-input" @bind-value="launchAngle" @bind-value:event="oninput" />
        </div>
        <div class="tile">
            <span class="tile-label">Spin</span>
            <input type="number" class="tile-input" @bind-value="spinRate" @bind-value:event="oninput" />
        </div>
        <button class="run-btn" @onclick="RunSimulation">LAUNCH</button>
    </div>
</div>

@code {
    private float ballSpeed = 150f;
    private float launchAngle = 12f;
    private float spinRate = 2500f;
    private SimulationResult? result;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("init3DTracer", "threeCanvas");
        }
    }

    private async Task RunSimulation()
    {
        var input = new ShotInput
        {
            BallSpeedMph = ballSpeed,
            LaunchAngleDeg = launchAngle,
            BackspinRpm = spinRate
        };

        result = Physics.Simulate(input);

        // Send trajectory to Three.js
        var jsPoints = result.Trajectory.Select(p => new
        {
            x = p.OfflineYards,
            y = p.AltitudeFeet / 3.28084f,
            z = p.DownrangeYards
        });

        await JS.InvokeVoidAsync("update3DTracer", System.Text.Json.JsonSerializer.Serialize(jsPoints));

        // Draw birdseye
        var topDown = result.Trajectory.Select(p => new
        {
            x = p.OfflineYards,
            z = p.DownrangeYards
        });

        await JS.InvokeVoidAsync("drawBirdseye", "birdseyeCanvas", System.Text.Json.JsonSerializer.Serialize(topDown));

        StateHasChanged();
    }
}
